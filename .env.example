# Browser (Vite) — safe for frontend
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_ALLOWED_EMAIL=

# Server-only (Vercel env vars — do NOT prefix with VITE_)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
ALLOWED_USER_EMAIL=
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
CRON_SECRET=
APP_URL=

# AI provider chain (Gemini → OpenRouter → Groq → Cerebras → NVIDIA → Mistral)
# Get GEMINI_API_KEY: https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.1-8b-instruct:free
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama3.1-8b
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.1-8b-instruct
MISTRAL_API_KEY=
MISTRAL_MODEL=mistral-small-latest
AI_GEMINI_MONTHLY_LIMIT=1200
AI_OPENROUTER_MONTHLY_LIMIT=1200
AI_GROQ_MONTHLY_LIMIT=1500
AI_CEREBRAS_MONTHLY_LIMIT=1500
AI_NVIDIA_MONTHLY_LIMIT=1500
AI_MISTRAL_MONTHLY_LIMIT=1500
AI_DAILY_CHAT_LIMIT=40
AI_PENDING_SECRET=
